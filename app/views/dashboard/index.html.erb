<!-- app/views/dashboard/index.html.erb -->
<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <h1 class="mb-4">Dashboard</h1>
    </div>
  </div>

  <div class="row">
    <!-- Current Subscription Card -->
    <div class="col-md-6 mb-4">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">Current Subscription</h5>
        </div>
        <div class="card-body">
          <% if current_user.has_active_subscription? %>
            <div class="subscription-info">
              <p><strong>Plan:</strong> <%= current_user.current_plan.display_name %></p>
              <p><strong>Status:</strong> 
                <span class="badge bg-success"><%= current_user.active_subscription.status.titleize %></span>
              </p>
              <p><strong>Current Period:</strong> 
                <%= current_user.active_subscription.current_period_start.to_date %> to 
                <%= current_user.active_subscription.current_period_end.to_date %>
              </p>
              <p><strong>Auto Renew:</strong> 
                <%= current_user.active_subscription.auto_renew ? 'Yes' : 'No' %>
              </p>
              
              <% if current_user.active_subscription.recurring? %>
                <%= link_to 'Cancel Subscription', 
                    subscription_path(current_user.active_subscription), 
                    method: :delete, 
                    data: { confirm: 'Are you sure you want to cancel your subscription?' },
                    class: 'btn btn-warning btn-sm' %>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No active subscription</p>
            <%= link_to 'Browse Plans', subscriptions_path, class: 'btn btn-primary' %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Recent Payments Card -->
    <div class="col-md-6 mb-4">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">Recent Payments</h5>
        </div>
        <div class="card-body">
          <% if @recent_payments.any? %>
            <div class="payment-list">
              <% @recent_payments.each do |payment| %>
                <div class="payment-item border-bottom pb-2 mb-2">
                  <div class="d-flex justify-content-between">
                    <div>
                      <strong>$<%= payment.amount %></strong>
                      <small class="text-muted d-block">
                        <%= payment.plan.plan_type.capitalize %> - 
                        <%= payment.payment_date.strftime('%b %d, %Y') %>
                      </small>
                    </div>
                    <div>
                      <span class="badge bg-<%= payment.successful? ? 'success' : 'danger' %>">
                        <%= payment.status.titleize %>
                      </span>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
            <%#= link_to 'View All Payments', dashboard_payment_history_path, class: 'btn btn-outline-primary btn-sm mt-2' %>
          <% else %>
            <p class="text-muted">No payments yet</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">Quick Actions</h5>
        </div>
        <div class="card-body">
          <div class="d-flex gap-2">
            <%= link_to 'Browse Plans', subscriptions_path, class: 'btn btn-primary' %>
            <%= link_to 'Payment History', dashboard_payment_history_path, class: 'btn btn-outline-secondary' %>
            <% if current_user.has_active_subscription? %>
              <%= link_to 'Subscription Details', dashboard_subscription_details_path, class: 'btn btn-outline-info' %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


